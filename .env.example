# =====================================================================
# Plantilla de variables de entorno para dpo-app.
# Copiá a .env.local y completá. El .env.local NO se commitea.
# Por tenant (Pampeana / Misiones / otro) los valores cambian — ojo.
# =====================================================================

# ---- Supabase (por tenant) ----
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---- Branding visible en la app ----
NEXT_PUBLIC_EMPRESA_NOMBRE="Mercosur Región Pampeana"
NEXT_PUBLIC_EMPRESA_NOMBRE_CORTO="Pampeana"

# ---- Chess ERP (varía por tenant) ----
CHESS_API_BASE_URL="https://<host>.chesserp.com/<empresa>/web/api/chess/v1"
CHESS_API_USER=""
CHESS_API_PASS=""

# ---- Foxtrot (token global; DCs por tenant) ----
FOXTROT_API_KEY=""
FOXTROT_DC_IDS="pergamino,ramallo"   # Pampeana. Misiones: "eldorado,iguazu"

# ---- Asistencia (matchea el x-api-key hardcoded del script PHP del biométrico) ----
ASISTENCIA_API_KEY=""

# ---- Cron secret (auth del cron diario contra /api/rechazos/sync y demás) ----
# Generar con:  openssl rand -hex 32
# Lo usa Vercel cron automáticamente (header `Authorization: Bearer <CRON_SECRET>`).
# El endpoint también acepta `x-api-key: <CRON_SECRET>` para invocaciones desde
# scripts externos. La UI sigue usando sesión Supabase — este secret nunca se
# expone al cliente. Compartido con otros crons del repo (requisitos-legales,
# reuniones, rechazos).
CRON_SECRET=""

# ---- OpenAI (opcional, para features con IA) ----
OPENAI_API_KEY=""

# ---- Vercel OIDC (lo regenera `vercel link` + `vercel env pull`) ----
# VERCEL_OIDC_TOKEN=""
